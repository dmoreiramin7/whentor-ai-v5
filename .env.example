# ─── Whentor AI — Environment Variables ────────────────────────────────────────
#
# Copy this file to .env and fill in your keys.
# The app works WITHOUT any keys (browser voice + text only).
# Adding ElevenLabs gives each mentor their unique premium voice.

# ElevenLabs — Premium AI voices for every mentor
# Get your free key at: https://elevenlabs.io
# Free tier: 10,000 characters/month (plenty for demos)
VITE_ELEVENLABS_API_KEY=

# ─── Coming soon ────────────────────────────────────────────────────────────────
# VITE_OPENAI_API_KEY=          # For real AI responses (currently uses smart pre-built logic)
# VITE_SUPABASE_URL=            # For cloud memory sync across devices
# VITE_SUPABASE_ANON_KEY=       # Supabase public key

# Fish Audio — celebrity voice clones (PRIMARY voice engine)
# Server-side only: set in Vercel → Settings → Environment Variables
# Get key at: https://fish.audio → API keys
# Per-advisor reference IDs go in src/lib/voice.ts → FISH_VOICES
FISH_AUDIO_API_KEY=
